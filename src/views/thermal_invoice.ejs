<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <title>Receipt - <%= invoice.invoice_no %>
    </title>
    <style>
        body {
            font-family: 'Courier New', Courier, monospace;
            width: 80mm;
            margin: 0;
            padding: 10px;
            font-size: 12px;
            color: #000;
            background: #fff;
        }

        .receipt-container {
            width: 100%;
        }

        .center {
            text-align: center;
        }

        .bold {
            font-weight: bold;
        }

        .header {
            margin-bottom: 10px;
            border-bottom: 1px dashed #000;
            padding-bottom: 10px;
        }

        .header h1 {
            font-size: 18px;
            margin: 0 0 5px 0;
        }

        .header p {
            margin: 2px 0;
            font-size: 11px;
        }

        .info {
            margin-bottom: 10px;
            border-bottom: 1px dashed #000;
            padding-bottom: 5px;
        }

        .info div {
            display: flex;
            justify-content: space-between;
        }

        table {
            width: 100%;
            border-collapse: collapse;
            margin-bottom: 10px;
        }

        table th {
            text-align: left;
            border-bottom: 1px dashed #000;
            padding: 5px 0;
            font-size: 11px;
        }

        table td {
            padding: 5px 0;
            vertical-align: top;
        }

        .summary {
            border-top: 1px dashed #000;
            padding-top: 5px;
        }

        .summary div {
            display: flex;
            justify-content: space-between;
            margin: 2px 0;
        }

        .summary .total {
            font-size: 14px;
            font-weight: bold;
            border-top: 1px solid #000;
            margin-top: 5px;
            padding-top: 5px;
        }

        .footer {
            margin-top: 15px;
            border-top: 1px dashed #000;
            padding-top: 10px;
            font-size: 10px;
        }

        @media print {
            body {
                width: 80mm;
                padding: 0;
                margin: 0;
            }

            .no-print {
                display: none;
            }
        }
    </style>
</head>

<body>
    <div class="receipt-container">
        <div class="header center">
            <h1>
                <%= settings.companyName || 'CLOTHING STORE' %>
            </h1>
            <% if (settings.companyAddress) { %>
                <p>
                    <%= settings.companyAddress.substring(0, 40) %>
                </p>
                <% } else { %>
                    <p>123 Fashion Street, City</p>
                    <% } %>
                        <p>PH: <%= settings.companyMobile1 || '+91 9876543210' %>
                        </p>
                        <% if (settings.companyGSTIN) { %>
                            <p>GSTIN: <%= settings.companyGSTIN %>
                            </p>
                            <% } %>
        </div>

        <div class="info">
            <div><span>INV NO:</span> <span class="bold">
                    <%= invoice.invoice_no %>
                </span></div>
            <div><span>DATE:</span> <span>
                    <%= new Date(invoice.invoice_date).toLocaleDateString('en-IN') %>
                </span></div>
            <div><span>CUST:</span> <span>
                    <%= invoice.customer_name || 'WALK-IN' %>
                </span></div>
            <% if (invoice.customer_phone) { %>
                <div><span>PHONE:</span> <span>
                        <%= invoice.customer_phone %>
                    </span></div>
                <% } %>
        </div>

        <table>
            <thead>
                <tr>
                    <th style="width: 50%;">ITEM</th>
                    <th style="text-align: center;">QTY</th>
                    <th style="text-align: right;">PRICE</th>
                </tr>
            </thead>
            <tbody>
                <% invoice.items.forEach(function(item) { %>
                    <tr>
                        <td>
                            <%= item.product_name.substring(0, 20) %>
                                <%= item.product_name.length> 20 ? '..' : '' %>
                        </td>
                        <td style="text-align: center;">
                            <%= item.quantity %>
                        </td>
                        <td style="text-align: right;">
                            <%= Number(item.total).toFixed(2) %>
                        </td>
                    </tr>
                    <% }); %>
            </tbody>
        </table>

        <div class="summary">
            <div><span>SUBTOTAL:</span> <span>
                    <%= Number(invoice.sub_total).toFixed(2) %>
                </span></div>
            <div><span>GST:</span> <span>
                    <%= Number(invoice.tax_amount).toFixed(2) %>
                </span></div>
            <% if (Number(invoice.discount)> 0) { %>
                <div><span>DISCOUNT:</span> <span>-<%= Number(invoice.discount).toFixed(2) %></span></div>
                <% } %>
                    <div class="total"><span>TOTAL:</span> <span>₹<%= Number(invoice.total_amount).toFixed(2) %></span>
                    </div>
                    <div style="margin-top: 5px;"><span>PAID:</span> <span>
                            <%= Number(invoice.paid_amount).toFixed(2) %>
                        </span></div>
                    <% if (Number(invoice.balance_due)> 0) { %>
                        <div><span>BALANCE:</span> <span>
                                <%= Number(invoice.balance_due).toFixed(2) %>
                            </span></div>
                        <% } %>
        </div>

        <div class="footer center">
            <p>PAYMENT: <%= invoice.payment_method || 'CASH' %>
            </p>
            <p class="bold">THANK YOU FOR VISITING!</p>
            <p>NO EXCHANGE / NO RETURN</p>
            <p>
                <%= new Date().toLocaleString() %>
            </p>
        </div>
    </div>
</body>

</html>